# Shared .env for BOTH back (Node/Express) and front (Vite)
# Location: WebServer/.env

# ----------------------
# Back (API)
# ----------------------
PORT=3000
CORS_ORIGIN=*

# Firebase RTDB (admin SDK in back)
FIREBASE_DATABASE_URL=https://<project>-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_SERVICE_ACCOUNT_FILE=../Raspberry/key.json
FIREBASE_TELEMETRY_PATH=/iot/telemetry
FIREBASE_HARDWARE_PATH=/iot/hardware

# MariaDB
MARIADB_DATABASE=tempsent
MARIADB_USER=tempsent
MARIADB_PASSWORD=tempsent
MARIADB_ROOT_PASSWORD=root

# Archive job
ARCHIVE_CRON_ENABLED=true
ARCHIVE_CRON_SCHEDULE="5 0 * * *"
ARCHIVE_OLDER_THAN_HOURS=24
ARCHIVE_PAGE_SIZE=500
ARCHIVE_DELETE_CHUNK_SIZE=500
TZ=Europe/Paris

# Forward actions -> Raspberry control server
RASPBERRY_CONTROL_BASE_URL=http://<ip-raspberry>:4000
RASPBERRY_CONTROL_TIMEOUT_MS=5000

# ----------------------
# Front (Vite)
# NOTE: Vite only exposes variables prefixed with VITE_
# ----------------------
VITE_API_BASE_URL=http://<ip-backend>:3000
