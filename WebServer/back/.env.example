# Server
PORT=8080

# Firebase RTDB
FIREBASE_DATABASE_URL=
# Exemple (à remplacer): https://<project>-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_SERVICE_ACCOUNT_FILE=../../Raspberry/key.json
FIREBASE_TELEMETRY_PATH=/iot/telemetry
FIREBASE_HARDWARE_PATH=/iot/hardware

# MariaDB
MARIADB_DATABASE=tempsent
MARIADB_USER=tempsent
MARIADB_PASSWORD=tempsent
MARIADB_ROOT_PASSWORD=root

# Archive job
ARCHIVE_CRON_ENABLED=true
ARCHIVE_CRON_SCHEDULE="5 0 * * *"
ARCHIVE_OLDER_THAN_HOURS=24
ARCHIVE_PAGE_SIZE=500
ARCHIVE_DELETE_CHUNK_SIZE=500
TZ=Europe/Paris

# Raspberry control server (API -> Raspberry -> MQTT)
RASPBERRY_CONTROL_BASE_URL=http://192.168.1.50:4000
RASPBERRY_CONTROL_TIMEOUT_MS=5000

# CORS (front)
CORS_ORIGIN=*
