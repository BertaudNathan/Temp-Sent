# MQTT (optionnel si tu gardes les valeurs par defaut)
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=mqtt-firebase-bridge
MQTT_TELEMETRY_TOPICS=iot/sensors/+/telemetry
MQTT_KPI_TOPICS=iot/sensors/+/info,iot/sensors/+/errors,iot/actuators/+/status

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://temp-sent-default-rtdb.europe-west1.firebasedatabase.app
# Chemin vers la cle service account JSON (dans ce repo)
FIREBASE_SERVICE_ACCOUNT_FILE=./key.json
FIREBASE_TELEMETRY_PATH=/iot/telemetry
FIREBASE_HARDWARE_PATH=/iot/hardware
