# MQTT (optionnel si tu gardes les valeurs par defaut)
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=mqtt-firebase-bridge
MQTT_TELEMETRY_TOPICS=iot/sensors/+/telemetry
MQTT_KPI_TOPICS=iot/sensors/+/info,iot/sensors/+/errors,iot/actuators/+/status

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.europe-west1.firebasedatabase.app
# Chemin absolu vers le fichier JSON de service account Firebase
FIREBASE_SERVICE_ACCOUNT_FILE=C:/Users/Nathan/keys/firebase-service-account.json

# Flux 1: Telemetrie (temperature, humidite)
FIREBASE_TELEMETRY_PATH=/iot/telemetry

# Flux 2: Hardware/KPI (status, erreurs, RAM, etc.)
FIREBASE_HARDWARE_PATH=/iot/hardware
