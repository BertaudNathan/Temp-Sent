# MQTT (optionnel si tu gardes les valeurs par defaut)
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=mqtt-rest-bridge
MQTT_TELEMETRY_TOPICS=iot/sensors/+/telemetry
MQTT_KPI_TOPICS=iot/sensors/+/info,iot/sensors/+/errors,iot/actuators/+/status

# REST backend (Vercel)
REST_BASE_URL=https://your-backend.vercel.app
REST_TELEMETRY_PATH=/api/iot/telemetry
REST_KPI_PATH=/api/iot/kpi
REST_AUTH_TOKEN=
